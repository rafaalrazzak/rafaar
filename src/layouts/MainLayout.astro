---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import Model3DViewer from '@/components/Model3DViewer.astro';
import GalaxyBackground from '@/components/GalaxyBackground.astro';

interface Props {
  title?: string;
  description?: string;
  showModel?: boolean;
}

const { title, description, showModel = true } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="relative flex min-h-screen flex-col overflow-x-hidden">
    <GalaxyBackground />

    {
      showModel && (
        <div transition:persist="3d-model">
          <Model3DViewer modelUrl="/models/logo.glb" height="100vh" enableGlare />
        </div>
      )
    }

    <Navbar class="relative z-50" />
    <main class="relative z-10 flex-1 pb-16 md:pb-24">
      <slot />
    </main>
  </div>
</BaseLayout>
