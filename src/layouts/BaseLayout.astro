---
import '@/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import siteMetadata from '@/data/site-metadata';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = siteMetadata.SITE_NAME, 
  description = siteMetadata.SITE_DESCRIPTION 
} = Astro.props;

const fullTitle = title === siteMetadata.SITE_NAME ? title : `${title} — rafaar`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <link rel="dns-prefetch" href="//ajax.googleapis.com" />
    <link rel="preconnect" href="https://ajax.googleapis.com" crossorigin />
    <link
      rel="modulepreload"
      href="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"
      crossorigin
    />
    <link rel="preload" href="/models/logo.glb" as="fetch" type="model/gltf-binary" />
    
    <!-- Theme initialization (before paint) -->
    <script is:inline>
      (function() {
        const root = document.documentElement;
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        root.classList.toggle('dark', theme === 'dark');
        root.style.colorScheme = theme;
      })();
    </script>
    
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteMetadata.SITE_URL} />
    <meta property="og:image" content={`${siteMetadata.SITE_URL}${siteMetadata.TWITTER_CARD}`} />
    <meta property="og:type" content="website" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteMetadata.TWITER_USERNAME} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteMetadata.SITE_URL}${siteMetadata.TWITTER_CARD}`} />
    
    <ClientRouter />

    <!-- Persist theme across page transitions -->
    <script is:inline>
      document.addEventListener('astro:before-swap', (ev) => {
        const root = document.documentElement;
        const isDark = root.classList.contains('dark');
        ev.newDocument.documentElement.classList.toggle('dark', isDark);
        ev.newDocument.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
      });
    </script>
    <script is:inline>
      const normalizeTrailingSlash = () => {
        const { pathname, search, hash } = window.location;
        if (pathname.length > 1 && pathname.endsWith('/')) {
          const normalized = pathname.replace(/\/+$/, '');
          history.replaceState(history.state, '', `${normalized}${search}${hash}`);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', normalizeTrailingSlash, { once: true });
      } else {
        normalizeTrailingSlash();
      }

      document.addEventListener('astro:after-swap', normalizeTrailingSlash);
    </script>
  </head>
  <body class="bg-background text-foreground antialiased">
    <slot />

    <script is:inline>
      // Re-apply active theme after navigation swaps
      document.addEventListener('astro:after-swap', () => {
        const root = document.documentElement;
        const isDark = root.classList.contains('dark');
        root.style.colorScheme = isDark ? 'dark' : 'light';
      });
    </script>
  </body>
</html>
