---
import { APP_ROUTE } from '@/data/app-route';
import ThemeToggle from './ThemeToggle';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<nav
  class:list={[
    'glass-panel sticky top-0 z-50 border-b border-border/40',
    className,
  ]}
>
  <div class="container mx-auto max-w-5xl px-6">
    <div class="flex h-14 items-center justify-between">
      <div class="flex items-center gap-6">
        {
          APP_ROUTE.map(({ path, name }) => (
            <a
              href={path}
              class:list={[
                'relative py-1 text-sm transition-colors duration-200',
                Astro.url.pathname === path
                  ? 'text-main font-medium'
                  : 'text-soft hover:text-main',
              ]}
            >
              {name}
              {Astro.url.pathname === path && (
                <span class="absolute bottom-0 left-0 right-0 h-px bg-foreground" />
              )}
            </a>
          ))
        }
      </div>
      <div transition:persist="theme-toggle">
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</nav>
