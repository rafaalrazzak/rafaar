---
import { cn } from '@/libs/utils';

interface Props {
  class?: string;
  as?: 'div' | 'span';
}

const { class: className, as = 'div' } = Astro.props;
const Tag = as;
---

<Tag
  class={cn(
    'border border-border/60 bg-card/80 shadow-xl backdrop-blur-xl backdrop-saturate-150',
    className,
  )}
>
  <slot />
</Tag>

