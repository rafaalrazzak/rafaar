---
import { Card } from '@almach/ui';
import { cn } from '@/libs/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Card
  className={cn(
    'border border-border/60 bg-card/75 shadow-lg backdrop-blur-2xl backdrop-saturate-150 transition-all duration-300 ease-out hover:border-foreground/20 hover:shadow-xl',
    className,
  )}
>
  <slot />
</Card>
