---
import { Badge } from '@almach/ui';
import { cn } from '@/libs/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Badge
  variant="secondary"
  className={cn(
    'border border-border/70 bg-background text-foreground',
    className,
  )}
>
  <slot />
</Badge>

