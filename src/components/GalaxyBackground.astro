<div
  transition:persist="galaxy-bg"
  data-fixed-visual
  class="pointer-events-none fixed inset-0 -z-10 overflow-hidden print:hidden"
>
  <div class="bg-background absolute inset-0 -z-10"></div>
  <canvas id="galaxy-canvas" class="absolute inset-0 -z-10 h-full w-full"
  ></canvas>
  <div data-aurora="a" class="absolute inset-0 -z-10"></div>
  <div data-aurora="b" class="absolute inset-0 -z-10"></div>
  <div data-aurora="c" class="absolute inset-0 -z-10"></div>

  <div
    data-overlay="a"
    class="absolute inset-0 -z-10 bg-[radial-gradient(120%_90%_at_15%_5%,rgba(59,130,246,0.18),transparent_52%),radial-gradient(90%_70%_at_85%_12%,rgba(14,165,233,0.14),transparent_56%),linear-gradient(180deg,rgba(248,250,252,0.92)_0%,rgba(241,245,249,0.82)_45%,rgba(248,250,252,0.92)_100%)] dark:bg-[radial-gradient(120%_95%_at_15%_5%,rgba(37,99,235,0.34),transparent_56%),radial-gradient(95%_75%_at_85%_12%,rgba(56,189,248,0.22),transparent_60%),linear-gradient(180deg,rgba(2,6,23,0.92)_0%,rgba(3,7,18,0.84)_45%,rgba(2,6,23,0.95)_100%)]"
  >
  </div>
  <div
    data-overlay="b"
    class="from-background/85 via-background/30 to-background/70 absolute inset-0 -z-10 bg-gradient-to-b"
  >
  </div>
  <div
    data-overlay="c"
    class="absolute inset-0 -z-10 bg-[radial-gradient(70%_55%_at_50%_65%,rgba(255,255,255,0.36),transparent_72%)] dark:bg-[radial-gradient(70%_55%_at_50%_65%,rgba(15,23,42,0.42),transparent_72%)]"
  >
  </div>
  <div
    data-overlay="d"
    class="absolute inset-0 -z-10 bg-[radial-gradient(55%_55%_at_50%_45%,rgba(59,130,246,0.12),transparent)] dark:bg-[radial-gradient(55%_55%_at_50%_45%,rgba(96,165,250,0.16),transparent)]"
  >
  </div>
  <div
    class="from-background absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b to-transparent"
  >
  </div>
</div>

<style>
  [data-aurora] {
    will-change: transform, opacity, filter;
    mix-blend-mode: normal;
    pointer-events: none;
  }

  :global(.dark) [data-aurora] {
    mix-blend-mode: screen;
  }

  [data-overlay] {
    pointer-events: none;
    will-change: transform, opacity;
    transform-origin: 50% 50%;
    inset: 0;
  }

  [data-overlay='a'] {
    animation: overlayDriftA 46s cubic-bezier(0.37, 0, 0.18, 1) infinite
      alternate;
  }

  [data-overlay='b'] {
    animation: overlayDriftB 38s cubic-bezier(0.37, 0, 0.18, 1) infinite
      alternate;
  }

  [data-overlay='c'] {
    animation: overlayPulse 28s ease-in-out infinite alternate;
  }

  [data-aurora='a'] {
    background:
      radial-gradient(
        55% 45% at 20% 30%,
        rgba(56, 189, 248, 0.38),
        transparent 72%
      ),
      radial-gradient(
        45% 40% at 78% 18%,
        rgba(59, 130, 246, 0.34),
        transparent 72%
      );
    animation: auroraDriftA 30s cubic-bezier(0.37, 0, 0.18, 1) infinite
      alternate;
    opacity: 0.82;
    filter: blur(18px);
  }

  [data-aurora='b'] {
    background:
      radial-gradient(
        48% 38% at 68% 66%,
        rgba(147, 197, 253, 0.34),
        transparent 72%
      ),
      radial-gradient(
        42% 36% at 34% 74%,
        rgba(96, 165, 250, 0.28),
        transparent 70%
      );
    animation: auroraDriftB 38s cubic-bezier(0.37, 0, 0.18, 1) infinite
      alternate;
    opacity: 0.72;
    filter: blur(24px);
  }

  [data-aurora='c'] {
    background: conic-gradient(
      from 180deg at 50% 50%,
      rgba(56, 189, 248, 0.14),
      rgba(30, 64, 175, 0.08),
      transparent 35%,
      rgba(96, 165, 250, 0.14),
      transparent 65%
    );
    animation: auroraRotate 56s linear infinite;
    opacity: 0.58;
    filter: blur(36px);
  }

  :global(.dark) [data-aurora='a'] {
    background:
      radial-gradient(
        55% 45% at 20% 30%,
        rgba(56, 189, 248, 0.28),
        transparent 72%
      ),
      radial-gradient(
        45% 40% at 78% 18%,
        rgba(37, 99, 235, 0.24),
        transparent 72%
      );
    opacity: 0.78;
  }

  :global(.dark) [data-aurora='b'] {
    background:
      radial-gradient(
        48% 38% at 68% 66%,
        rgba(96, 165, 250, 0.2),
        transparent 72%
      ),
      radial-gradient(
        42% 36% at 34% 74%,
        rgba(59, 130, 246, 0.18),
        transparent 70%
      );
    opacity: 0.68;
  }

  :global(.dark) [data-aurora='c'] {
    opacity: 0.58;
  }

  @keyframes auroraDriftA {
    0% {
      transform: translate3d(-2%, 0%, 0) scale(1);
    }
    100% {
      transform: translate3d(3%, -2%, 0) scale(1.06);
    }
  }

  @keyframes auroraDriftB {
    0% {
      transform: translate3d(2%, 1%, 0) scale(1);
    }
    100% {
      transform: translate3d(-3%, -2%, 0) scale(1.08);
    }
  }

  @keyframes auroraRotate {
    0% {
      transform: rotate(0deg) scale(1);
    }
    100% {
      transform: rotate(360deg) scale(1.08);
    }
  }

  @keyframes overlayDriftA {
    0% {
      transform: translate3d(-1.2%, 0.6%, 0) scale(1.03);
      opacity: 0.72;
    }
    100% {
      transform: translate3d(1.1%, -0.8%, 0) scale(1.05);
      opacity: 0.84;
    }
  }

  @keyframes overlayDriftB {
    0% {
      transform: translate3d(1.4%, 0.8%, 0) scale(1.02);
      opacity: 0.56;
    }
    100% {
      transform: translate3d(-1.5%, -1%, 0) scale(1.04);
      opacity: 0.68;
    }
  }

  @keyframes overlayPulse {
    0% {
      opacity: 0.5;
      transform: scale(0.985);
    }
    100% {
      opacity: 0.68;
      transform: scale(1.03);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-aurora],
    [data-overlay] {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    if (window.__galaxyCanvasInit) return;
    window.__galaxyCanvasInit = true;

    const canvas = document.getElementById('galaxy-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = 1;
    let resizeRaf = 0;
    let stars = [];
    let rays = [];
    let driftTime = 0;
    let orbitRotation = 0;
    let lastTs = 0;

    const isDark = () => document.documentElement.classList.contains('dark');

    const createStars = (count) => {
      const next = [];
      for (let i = 0; i < count; i++) {
        next.push({
          x: Math.random() * width,
          y: Math.random() * height,
          r: Math.random() * 1.3 + 0.2,
          alpha: Math.random() * 0.6 + 0.1,
          twinkle: Math.random() * Math.PI * 2,
          twinkleSpeed: Math.random() * 0.02 + 0.005,
        });
      }
      return next;
    };

    const createRays = (count) => {
      const next = [];
      for (let i = 0; i < count; i++) {
        next.push({
          angle: Math.random() * Math.PI * 2,
          distance: Math.random() * width,
          speed: Math.random() * 1.3 + 0.55,
          length: Math.random() * 66 + 48,
          lineWidth: Math.random() * 1.1 + 0.45,
          hue: 214 + Math.random() * 64,
        });
      }
      return next;
    };

    const setup = () => {
      dpr = Math.max(1, window.devicePixelRatio || 1);
      width = Math.max(1, Math.floor(canvas.offsetWidth));
      height = Math.max(1, Math.floor(canvas.offsetHeight));

      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);

      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);

      const starCount = width < 768 ? 120 : 220;
      const rayCount = width < 768 ? 130 : 230;
      stars = createStars(starCount);
      rays = createRays(rayCount);
    };

    const drawStars = (dark) => {
      for (let i = 0; i < stars.length; i++) {
        const s = stars[i];
        s.twinkle += s.twinkleSpeed;
        const pulse = 0.85 + Math.sin(driftTime + i * 0.07) * 0.15;
        const alpha =
          s.alpha *
          (0.7 + Math.sin(s.twinkle) * 0.3) *
          pulse *
          (dark ? 1 : 0.7);
        ctx.beginPath();
        ctx.fillStyle = `rgba(${dark ? '255,255,255' : '15,23,42'}, ${alpha})`;
        const driftX = Math.sin(driftTime * 0.4 + s.twinkle) * 0.35;
        const driftY = Math.cos(driftTime * 0.3 + s.twinkle) * 0.25;
        ctx.arc(s.x + driftX, s.y + driftY, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    const drawRays = (dark) => {
      const cx = width / 2;
      const cy = height / 2;
      ctx.globalCompositeOperation = 'screen';
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      for (let i = 0; i < rays.length; i++) {
        const ray = rays[i];
        ray.distance += ray.speed;
        ray.angle += dark ? 0.00024 : 0.00018;
        if (ray.distance > width) {
          ray.distance = 0;
          ray.angle = Math.random() * Math.PI * 2;
        }

        const theta = ray.angle + orbitRotation;
        const x1 = cx + Math.cos(theta) * ray.distance;
        const y1 = cy + Math.sin(theta) * ray.distance;
        const x2 = cx + Math.cos(theta) * (ray.distance + ray.length);
        const y2 = cy + Math.sin(theta) * (ray.distance + ray.length);
        const fade = Math.min(1, ray.distance / (width * 0.3));
        const alpha = fade * (dark ? 0.62 : 0.28);

        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.strokeStyle = `hsla(${ray.hue}, 100%, 65%, ${alpha})`;
        ctx.lineWidth = ray.lineWidth;
        ctx.stroke();
      }

      ctx.globalCompositeOperation = 'source-over';
    };

    const frame = (ts = performance.now()) => {
      if (!lastTs) lastTs = ts;
      const dt = Math.min(33, ts - lastTs);
      const step = dt / 16.67;
      lastTs = ts;
      const dark = isDark();
      driftTime += 0.0032 * step;
      orbitRotation += (dark ? 0.00042 : 0.00032) * step;
      ctx.clearRect(0, 0, width, height);

      const wash = dark ? '10,10,12' : '249,250,251';
      const washAlpha = dark ? 0.08 : 0.07;
      ctx.fillStyle = `rgba(${wash}, ${washAlpha})`;
      ctx.fillRect(0, 0, width, height);

      const glow = ctx.createRadialGradient(
        width / 2,
        height / 2,
        0,
        width / 2,
        height / 2,
        height
      );
      glow.addColorStop(
        0,
        dark ? 'rgba(56,189,248,0.24)' : 'rgba(59,130,246,0.24)'
      );
      glow.addColorStop(
        0.42,
        dark ? 'rgba(37,99,235,0.1)' : 'rgba(96,165,250,0.12)'
      );
      glow.addColorStop(1, 'transparent');
      ctx.fillStyle = glow;
      ctx.fillRect(0, 0, width, height);

      drawStars(dark);
      drawRays(dark);
      requestAnimationFrame(frame);
    };

    const onResize = () => {
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(setup);
    };

    window.addEventListener('resize', onResize, { passive: true });
    document.addEventListener('astro:page-load', onResize);

    setup();
    frame();
  })();
</script>
