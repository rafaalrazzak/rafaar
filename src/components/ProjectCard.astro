---
import type { Project } from '@/types';
import { Card } from '@almach/ui';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <Card>
    <div
      class="bg-muted flex size-12 shrink-0 items-center justify-center rounded-lg"
    >
      <project.icon className="text-muted-foreground size-6" />
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="truncate font-semibold">{project.title}</h3>
      <p class="text-muted-foreground line-clamp-2 text-sm">
        {project.description}
      </p>
    </div>
  </Card>
</a>
