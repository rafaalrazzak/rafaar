---
import type { Project } from '@/types';
import GlassCard from '@/components/ui/GlassCard.astro';
import GlassPanel from '@/components/ui/GlassPanel.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <GlassCard class="p-6 hover:-translate-y-0.5">
    <GlassPanel class="flex size-12 shrink-0 items-center justify-center rounded-lg">
      <project.icon className="text-muted-foreground hover:text-foreground size-6 transition-colors" />
    </GlassPanel>
    <div class="min-w-0 flex-1">
      <h3 class="text-foreground truncate font-semibold">{project.title}</h3>
      <p class="text-muted-foreground line-clamp-2 text-sm">
        {project.description}
      </p>
    </div>
  </GlassCard>
</a>
