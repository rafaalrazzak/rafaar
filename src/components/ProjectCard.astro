---
import type { Project } from '@/types';
import GlassCard from '@/components/ui/GlassCard.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <GlassCard class="p-6 hover:-translate-y-0.5">
    <div
      class="glass-panel flex size-12 shrink-0 items-center justify-center rounded-lg"
    >
      <project.icon className="icon-tone size-6" />
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="text-main truncate font-semibold">{project.title}</h3>
      <p class="text-soft line-clamp-2 text-sm">
        {project.description}
      </p>
    </div>
  </GlassCard>
</a>
