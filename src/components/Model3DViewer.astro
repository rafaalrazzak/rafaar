---
interface Props {
  modelUrl: string;
  height?: string;
  enableGlare?: boolean;
  alt?: string;
  cameraOrbit?: string;
  cameraTarget?: string;
  fieldOfView?: string;
  exposure?: string;
  shadowIntensity?: string;
  shadowSoftness?: string;
}

const {
  modelUrl,
  height = "100vh",
  enableGlare = true,
  alt = "3D logo",
  cameraOrbit = "75deg 65deg 180%",
  cameraTarget = "auto auto auto",
  fieldOfView = "35deg",
  exposure = "0.92",
  shadowIntensity = "0.34",
  shadowSoftness = "1.4",
} = Astro.props;
---

<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>

<model-viewer
  id="animated-model"
  src={modelUrl}
  alt={alt}
  auto-rotate
  auto-rotate-delay="0"
  rotation-per-second="12deg"
  camera-controls
  touch-action="pan-y"
  interaction-prompt="none"
  tone-mapping="neutral"
  environment-image="neutral"
  camera-orbit={cameraOrbit}
  camera-target={cameraTarget}
  field-of-view={fieldOfView}
  exposure={exposure}
  shadow-intensity={shadowIntensity}
  shadow-softness={shadowSoftness}
  min-camera-orbit="auto auto 150%"
  max-camera-orbit="auto auto 250%"
  interpolation-decay="200"
  class="model-viewer-custom fixed inset-0 z-[2]"
  style={`height:${height};width:100%;transition:opacity .35s ease,filter .35s ease,transform .35s ease;`}
>
</model-viewer>

{
  enableGlare && (
    <div class="scene-glow pointer-events-none fixed inset-0 z-[1]">
      <div class="scene-vignette"></div>
      <div class="scene-ambient"></div>
    </div>
  )
}

<script is:inline>
  function applyViewerTheme(viewer) {
    const isDark = document.documentElement.classList.contains("dark");

    if (isDark) {
      viewer.exposure = "0.92";
      viewer.shadowIntensity = "0.34";
      viewer.shadowSoftness = "1.4";
      viewer.style.opacity = "0.76";
      viewer.style.mixBlendMode = "screen";
      viewer.style.filter = "none";
      viewer.style.transform = "translateZ(0)";
    } else {
      viewer.exposure = "1.03";
      viewer.shadowIntensity = "0.58";
      viewer.shadowSoftness = "0.95";
      viewer.style.opacity = "0.58";
      viewer.style.mixBlendMode = "normal";
      viewer.style.filter =
        "brightness(1.18) contrast(0.8) saturate(0.6) drop-shadow(0 16px 24px rgba(15,23,42,0.1))";
      viewer.style.transform = "translateZ(0)";
    }
  }

  function initModelViewerThemeSync() {
    const viewer = document.getElementById("animated-model");
    if (!viewer) return;

    applyViewerTheme(viewer);

    const observer = new MutationObserver(() => applyViewerTheme(viewer));
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    document.addEventListener(
      "astro:before-swap",
      () => {
        observer.disconnect();
      },
      { once: true },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initModelViewerThemeSync, { once: true });
  } else {
    initModelViewerThemeSync();
  }

  document.addEventListener("astro:page-load", initModelViewerThemeSync);
</script>

<style>
  .model-viewer-custom {
    --poster-color: transparent;
    pointer-events: none;
  }

  .scene-glow {
    opacity: 1;
    transition: opacity 0.35s ease;
  }

  .scene-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 28%, color-mix(in oklab, var(--color-foreground) 6%, transparent) 85%);
    opacity: 0.55;
  }

  .scene-ambient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, color-mix(in oklab, var(--color-muted) 65%, transparent) 0%, transparent 72%);
    opacity: 0.45;
  }

  :global(html:not(.dark)) .scene-vignette {
    opacity: 0.28;
  }

  :global(html:not(.dark)) .scene-ambient {
    opacity: 0.2;
  }
</style>

