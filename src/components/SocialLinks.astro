---
import { socialMedia } from '@/data/social-media';
import { Button } from '@almach/ui';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={className}>
  {socialMedia.map((social) => (
    <Button
      asChild
      variant="outline"
      size="icon"
      className="text-muted-foreground hover:text-foreground size-10 border border-border/60 bg-background/55 shadow-lg backdrop-blur-xl backdrop-saturate-150"
    >
      <a href={social.url} target="_blank" rel="noopener noreferrer">
        <social.icon className="text-muted-foreground hover:text-foreground size-4 fill-current transition-colors" />
        <span class="sr-only">{social.name}</span>
      </a>
    </Button>
  ))}
</div>
