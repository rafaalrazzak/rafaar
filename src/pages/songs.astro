---
import MainLayout from '@/layouts/MainLayout.astro';
import { MusicIcon } from 'lucide-react';
import PageShell from '@/components/layout/PageShell.astro';
import PageStack from '@/components/layout/PageStack.astro';
import PageHero from '@/components/layout/PageHero.astro';
import SectionStack from '@/components/layout/SectionStack.astro';
import PageHeading from '@/components/typography/PageHeading.astro';
import PageLead from '@/components/typography/PageLead.astro';
---

<MainLayout title="Songs">
  <PageShell>
    <PageStack>
      <!-- Header -->
      <PageHero>
        <div class="space-y-6">
          <PageHeading>Music</PageHeading>
          <PageLead>
            What I'm listening to and my favorite tracks.
          </PageLead>
        </div>
      </PageHero>

      <!-- Content -->
      <SectionStack>
        <div class="flex flex-col items-center justify-center space-y-4 py-16 text-center">
          <MusicIcon className="text-muted-foreground size-8" />
          <p class="text-muted-foreground text-sm">Coming soon...</p>
        </div>
      </SectionStack>
    </PageStack>
  </PageShell>
</MainLayout>
