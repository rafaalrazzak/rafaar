---
import MainLayout from '@/layouts/MainLayout.astro';
import { MusicIcon } from 'lucide-react';
import GlassCard from '@/components/ui/GlassCard.astro';
---

<MainLayout title="Songs">
  <div class="container mx-auto max-w-5xl px-6 py-20">
    <div class="space-y-20">
      <!-- Header -->
      <section class="max-w-3xl space-y-8">
        <div class="space-y-6">
          <h1 class="text-5xl font-medium tracking-tight md:text-6xl">Music</h1>
          <p class="text-soft text-lg leading-relaxed md:text-xl">
            What I'm listening to and my favorite tracks.
          </p>
        </div>
      </section>

      <!-- Content -->
      <section class="space-y-6">
        <div class="space-y-4">
          <GlassCard class="p-6">
          <div
            class="flex flex-col items-center justify-center space-y-4 py-16 text-center"
          >
            <div
              class="glass-panel flex size-16 items-center justify-center rounded-full"
            >
              <MusicIcon className="icon-tone size-8" />
            </div>
            <p class="text-soft text-sm">Coming soon...</p>
          </div>
          </GlassCard>
        </div>
      </section>
    </div>
  </div>
</MainLayout>
