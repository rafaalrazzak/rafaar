---
import MainLayout from '@/layouts/MainLayout.astro';
import { Badge } from '@almach/ui';
import { Card } from '@almach/ui';
import { RESUME_DATA } from '@/data/resume-data';
import { tools } from '@/data/tools';
import { GlobeIcon, MailIcon } from 'lucide-react';

const allTools = tools.flatMap((tool) => tool.item);
---

<MainLayout
  title={`${RESUME_DATA.name} | CV`}
  description={RESUME_DATA.summary}
>
  <div class="container mx-auto max-w-5xl px-6 py-20">
    <div class="space-y-12">
      <!-- Header -->
      <section class="space-y-6">
        <div class="space-y-4">
          <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">
            {RESUME_DATA.name}
          </h1>
          <p
            class="text-muted-foreground max-w-3xl text-base leading-relaxed md:text-lg"
          >
            {RESUME_DATA.summary}
          </p>
        </div>

        <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
          <a
            href={RESUME_DATA.locationLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2"
          >
            <GlobeIcon className="size-4" />
            <span>{RESUME_DATA.location}</span>
          </a>
          {
            RESUME_DATA.contact.email && (
              <a
                href={`mailto:${RESUME_DATA.contact.email}`}
                class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2"
              >
                <MailIcon className="size-4" />
                <span>{RESUME_DATA.contact.email}</span>
              </a>
            )
          }
        </div>
      </section>

      <!-- Work Experience -->
      <section class="space-y-6">
        <h2
          class="text-muted-foreground text-xs font-medium tracking-widest uppercase"
        >
          Work Experience
        </h2>
        <div class="space-y-3">
          {
            RESUME_DATA.work.map((work) => (
              <a
                href={work.link}
                target="_blank"
                rel="noopener noreferrer"
                class="block"
              >
                <Card className="border-border/70 bg-card p-5 shadow-none transition-colors hover:border-foreground/20">
                  <div class="space-y-3">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1 space-y-1">
                        <h3 class="text-foreground font-medium">
                          {work.company}
                        </h3>
                        <p class="text-muted-foreground text-sm">
                          {work.title}
                        </p>
                      </div>
                      <span class="text-muted-foreground text-sm whitespace-nowrap">
                        {work.start}—{work.end}
                      </span>
                    </div>
                    <p class="text-muted-foreground/90 text-sm leading-relaxed">
                      {work.description}
                    </p>
                    <div class="flex flex-wrap gap-1.5">
                      {work.badges.map((badge) => (
                        <Badge>{badge}</Badge>
                      ))}
                    </div>
                  </div>
                </Card>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Education -->
      <section class="space-y-6">
        <h2
          class="text-muted-foreground text-xs font-medium tracking-widest uppercase"
        >
          Education
        </h2>
        <div class="space-y-3">
          {
            RESUME_DATA.education.map((edu) => (
              <div class="border-border/70 bg-card rounded-lg border p-4">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-medium">{edu.school}</h3>
                  <span class="text-muted-foreground text-sm whitespace-nowrap">
                    {edu.start}—{edu.end}
                  </span>
                </div>
                <p class="text-muted-foreground text-sm">{edu.degree}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Skills -->
      <section class="space-y-6">
        <h2
          class="text-muted-foreground text-xs font-medium tracking-widest uppercase"
        >
          Skills &amp; Tools
        </h2>
        <div class="border-border/70 bg-card rounded-lg border p-4">
          <div class="flex flex-wrap gap-1.5">
            {allTools.map((tool) => <Badge>{tool}</Badge>)}
          </div>
        </div>
      </section>
    </div>
  </div>
</MainLayout>
