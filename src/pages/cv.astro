---
import MainLayout from '@/layouts/MainLayout.astro';
import { RESUME_DATA } from '@/data/resume-data';
import { tools } from '@/data/tools';
import { GlobeIcon, MailIcon } from 'lucide-react';
import GlassCard from '@/components/ui/GlassCard.astro';
import Chip from '@/components/ui/Chip.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import InlineLink from '@/components/ui/InlineLink.astro';
import PageShell from '@/components/layout/PageShell.astro';
import PageHeading from '@/components/typography/PageHeading.astro';
import PageLead from '@/components/typography/PageLead.astro';

const allTools = tools.flatMap((tool) => tool.item);
---

<MainLayout
  title={`${RESUME_DATA.name} | CV`}
  description={RESUME_DATA.summary}
  showModel={false}
>
  <PageShell>
    <div class="space-y-12">
      <!-- Header -->
      <section class="space-y-6">
        <div class="space-y-4">
          <PageHeading class="text-4xl font-semibold md:text-5xl">
            {RESUME_DATA.name}
          </PageHeading>
          <PageLead class="max-w-3xl text-base md:text-lg">
            {RESUME_DATA.summary}
          </PageLead>
        </div>

        <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
          <InlineLink
            href={RESUME_DATA.locationLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            <GlobeIcon className="text-muted-foreground hover:text-foreground size-4 transition-colors" />
            <span>{RESUME_DATA.location}</span>
          </InlineLink>
          {
            RESUME_DATA.contact.email && (
              <InlineLink href={`mailto:${RESUME_DATA.contact.email}`}>
                <MailIcon className="text-muted-foreground hover:text-foreground size-4 transition-colors" />
                <span>{RESUME_DATA.contact.email}</span>
              </InlineLink>
            )
          }
        </div>
      </section>

      <!-- Work Experience -->
      <section class="space-y-6">
        <SectionTitle>Work Experience</SectionTitle>
        <div class="space-y-3">
          {
            RESUME_DATA.work.map((work) => (
              <a
                href={work.link}
                target="_blank"
                rel="noopener noreferrer"
                class="block"
              >
                <GlassCard class="p-5">
                  <div class="space-y-3">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1 space-y-1">
                        <h3 class="text-foreground font-medium">
                          {work.company}
                        </h3>
                        <p class="text-muted-foreground text-sm">
                          {work.title}
                        </p>
                      </div>
                      <span class="text-muted-foreground text-sm whitespace-nowrap">
                        {work.start}—{work.end}
                      </span>
                    </div>
                    <p class="text-muted-foreground text-sm leading-relaxed">
                      {work.description}
                    </p>
                    <div class="flex flex-wrap gap-1.5">
                      {work.badges.map((badge) => (
                        <Chip>{badge}</Chip>
                      ))}
                    </div>
                  </div>
                </GlassCard>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Education -->
      <section class="space-y-6">
        <SectionTitle>Education</SectionTitle>
        <div class="space-y-3">
          {
            RESUME_DATA.education.map((edu) => (
              <div class="rounded-lg border border-border/70 bg-background/55 p-4 backdrop-blur-2xl backdrop-saturate-150 dark:border-white/15 dark:bg-zinc-950/58">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-medium">{edu.school}</h3>
                  <span class="text-muted-foreground text-sm whitespace-nowrap">
                    {edu.start}—{edu.end}
                  </span>
                </div>
                <p class="text-muted-foreground text-sm">{edu.degree}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Skills -->
      <section class="space-y-6">
        <SectionTitle>Skills &amp; Tools</SectionTitle>
        <div class="rounded-lg border border-border/70 bg-background/55 p-4 backdrop-blur-2xl backdrop-saturate-150 dark:border-white/15 dark:bg-zinc-950/58">
          <div class="flex flex-wrap gap-1.5">
            {allTools.map((tool) => <Chip>{tool}</Chip>)}
          </div>
        </div>
      </section>
    </div>
  </PageShell>
</MainLayout>
