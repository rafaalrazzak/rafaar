---
import MainLayout from '@/layouts/MainLayout.astro';
import { Badge } from '@almach/ui';
import { RESUME_DATA } from '@/data/resume-data';
import { MailIcon } from 'lucide-react';
import GlassCard from '@/components/ui/GlassCard.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import InlineLink from '@/components/ui/InlineLink.astro';
---

<MainLayout>
  <div class="page-shell">
    <div class="page-stack">
      <!-- Hero -->
      <section class="page-hero">
        <div class="space-y-6">
          <h1 class="page-heading">
            {RESUME_DATA.name}
          </h1>
          <p class="page-lead">
            {RESUME_DATA.about}
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          {RESUME_DATA.skills.map((skill) => <Badge variant="secondary" className="chip-soft">{skill}</Badge>)}
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {
            RESUME_DATA.contact.email && (
              <InlineLink href={`mailto:${RESUME_DATA.contact.email}`}>
                <MailIcon className="icon-tone size-4" />
                <span>Email</span>
              </InlineLink>
            )
          }
          {
            RESUME_DATA.contact.social.map((social) => (
              <InlineLink
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <social.icon className="icon-tone size-4 fill-current" />
                <span>{social.name}</span>
              </InlineLink>
            ))
          }
        </div>
      </section>

      <!-- Work -->
      {
        RESUME_DATA.work.length > 0 && (
          <section class="section-stack">
            <SectionTitle>Work</SectionTitle>
            <div class="card-stack">
              {RESUME_DATA.work.map((work) => (
                <a
                  href={work.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <GlassCard class="p-6 hover:-translate-y-0.5">
                    <div class="space-y-3">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 space-y-1">
                          <h3 class="text-main font-medium">
                            {work.company}
                          </h3>
                          <p class="text-soft text-sm">
                            {work.title}
                          </p>
                        </div>
                        <span class="text-soft text-sm whitespace-nowrap">
                          {work.start}—{work.end}
                        </span>
                      </div>
                      <p class="text-soft text-sm leading-relaxed">
                        {work.description}
                      </p>
                    </div>
                  </GlassCard>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Skills -->
      <div class="grid gap-16 md:grid-cols-2">
        <section class="section-stack">
          <SectionTitle>Languages</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.languages.map((lang) => <Badge variant="secondary" className="chip-soft">{lang}</Badge>)}
            </div>
          </div>
        </section>

        <section class="section-stack">
          <SectionTitle>Tools</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.tools.map((tool) => <Badge variant="secondary" className="chip-soft">{tool}</Badge>)}
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</MainLayout>
