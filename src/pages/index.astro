---
import MainLayout from '@/layouts/MainLayout.astro';
import { RESUME_DATA } from '@/data/resume-data';
import { MailIcon, FileTextIcon } from 'lucide-react';
import GlassCard from '@/components/ui/GlassCard.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import InlineLink from '@/components/ui/InlineLink.astro';
import Chip from '@/components/ui/Chip.astro';
import PageShell from '@/components/layout/PageShell.astro';
import PageStack from '@/components/layout/PageStack.astro';
import PageHero from '@/components/layout/PageHero.astro';
import SectionStack from '@/components/layout/SectionStack.astro';
import CardStack from '@/components/layout/CardStack.astro';
import PageHeading from '@/components/typography/PageHeading.astro';
import PageLead from '@/components/typography/PageLead.astro';
---

<MainLayout>
  <PageShell>
    <PageStack>
      <!-- Hero -->
      <PageHero>
        <div class="space-y-6">
          <PageHeading>
            {RESUME_DATA.name}
          </PageHeading>
          <PageLead>
            {RESUME_DATA.about}
          </PageLead>
        </div>

        <div class="flex flex-wrap gap-2">
          {RESUME_DATA.skills.map((skill) => <Chip>{skill}</Chip>)}
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {
            RESUME_DATA.contact.email && (
              <InlineLink href={`mailto:${RESUME_DATA.contact.email}`}>
                <MailIcon className="text-muted-foreground hover:text-foreground size-4 transition-colors" />
                <span>Email</span>
              </InlineLink>
            )
          }
          {
            RESUME_DATA.contact.social.map((social) => (
              <InlineLink
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <social.icon className="text-muted-foreground hover:text-foreground size-4 fill-current transition-colors" />
                <span>{social.name}</span>
              </InlineLink>
            ))
          }
          <InlineLink href="/cv">
            <FileTextIcon className="text-muted-foreground hover:text-foreground size-4 transition-colors" />
            <span>Curriculum Vitae</span>
          </InlineLink>
        </div>
      </PageHero>

      <!-- Work -->
      {
        RESUME_DATA.work.length > 0 && (
          <SectionStack>
            <SectionTitle>Work</SectionTitle>
            <CardStack>
              {RESUME_DATA.work.map((work) => (
                <a
                  href={work.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block group"
                >
                  <GlassCard class="p-6 transition-all duration-300 hover:-translate-y-0.5 flex flex-col sm:flex-row gap-5">
                    {work.logo && (
                      <div class="hidden sm:block shrink-0">
                        <div class="flex h-16 w-16 items-center justify-center overflow-hidden rounded-xl border border-border/50 bg-card shadow-sm">
                          <img 
                            src={work.logo} 
                            alt={`${work.company} logo`} 
                            class="h-10 w-10 object-contain transition-transform duration-500 group-hover:scale-110" 
                            loading="lazy"
                          />
                        </div>
                      </div>
                    )}
                    <div class="space-y-3 flex-1">
                      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 sm:gap-4">
                        <div class="flex items-start gap-4 sm:gap-0">
                          {work.logo && (
                            <div class="sm:hidden flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-border/50 bg-card shadow-sm">
                              <img 
                                src={work.logo} 
                                alt={`${work.company} logo`} 
                                class="h-8 w-8 object-contain" 
                                loading="lazy"
                              />
                            </div>
                          )}
                          <div class="space-y-1">
                            <h3 class="text-foreground font-semibold text-lg group-hover:text-primary transition-colors">
                              {work.company}
                            </h3>
                            <p class="text-muted-foreground font-medium">
                              {work.title}
                            </p>
                          </div>
                        </div>
                        <span class="text-muted-foreground text-sm font-medium whitespace-nowrap mt-1 sm:mt-0">
                          {work.start} — {work.end}
                        </span>
                      </div>
                      <p class="text-muted-foreground text-sm leading-relaxed max-w-3xl">
                        {work.description}
                      </p>
                      {work.badges && work.badges.length > 0 && (
                        <div class="flex flex-wrap gap-2 pt-1">
                          {work.badges.map((badge) => (
                            <Chip>{badge}</Chip>
                          ))}
                        </div>
                      )}
                    </div>
                  </GlassCard>
                </a>
              ))}
            </CardStack>
          </SectionStack>
        )
      }

      <!-- Projects -->
      {
        RESUME_DATA.projects && RESUME_DATA.projects.length > 0 && (
          <SectionStack>
            <SectionTitle>Projects</SectionTitle>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {RESUME_DATA.projects.map((project) => (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block group h-full"
                >
                  <GlassCard class="flex flex-col h-full overflow-hidden hover:-translate-y-0.5 transition-all duration-300">
                    {project.thumbnail && (
                      <div class="aspect-video w-full overflow-hidden border-b border-border/50 bg-muted">
                        <img 
                          src={project.thumbnail} 
                          alt={project.title} 
                          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                          loading="lazy" 
                        />
                      </div>
                    )}
                    <div class="p-6 space-y-4 flex flex-col flex-1">
                      <div class="space-y-2 flex-1">
                        <h3 class="text-foreground font-medium group-hover:opacity-80 transition-opacity">
                          {project.title}
                        </h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">
                          {project.description}
                        </p>
                      </div>
                      {project.badges && project.badges.length > 0 && (
                        <div class="flex flex-wrap gap-2 pt-1 mt-auto">
                          {project.badges.map((badge) => (
                            <Chip>{badge}</Chip>
                          ))}
                        </div>
                      )}
                    </div>
                  </GlassCard>
                </a>
              ))}
            </div>
          </SectionStack>
        )
      }

      <!-- Skills -->
      <div class="grid gap-16 md:grid-cols-2">
        <SectionStack>
          <SectionTitle>Languages</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.languages.map((lang) => <Chip>{lang}</Chip>)}
            </div>
          </div>
        </SectionStack>

        <SectionStack>
          <SectionTitle>Tools</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.tools.map((tool) => <Chip>{tool}</Chip>)}
            </div>
          </div>
        </SectionStack>
      </div>
    </PageStack>
  </PageShell>
</MainLayout>
