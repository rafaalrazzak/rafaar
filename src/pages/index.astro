---
import MainLayout from '@/layouts/MainLayout.astro';
import { RESUME_DATA } from '@/data/resume-data';
import { MailIcon } from 'lucide-react';
import GlassCard from '@/components/ui/GlassCard.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import InlineLink from '@/components/ui/InlineLink.astro';
import Chip from '@/components/ui/Chip.astro';
import PageShell from '@/components/layout/PageShell.astro';
import PageStack from '@/components/layout/PageStack.astro';
import PageHero from '@/components/layout/PageHero.astro';
import SectionStack from '@/components/layout/SectionStack.astro';
import CardStack from '@/components/layout/CardStack.astro';
import PageHeading from '@/components/typography/PageHeading.astro';
import PageLead from '@/components/typography/PageLead.astro';
---

<MainLayout>
  <PageShell>
    <PageStack>
      <!-- Hero -->
      <PageHero>
        <div class="space-y-6">
          <PageHeading>
            {RESUME_DATA.name}
          </PageHeading>
          <PageLead>
            {RESUME_DATA.about}
          </PageLead>
        </div>

        <div class="flex flex-wrap gap-2">
          {RESUME_DATA.skills.map((skill) => <Chip>{skill}</Chip>)}
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {
            RESUME_DATA.contact.email && (
              <InlineLink href={`mailto:${RESUME_DATA.contact.email}`}>
                <MailIcon className="text-muted-foreground hover:text-foreground size-4 transition-colors" />
                <span>Email</span>
              </InlineLink>
            )
          }
          {
            RESUME_DATA.contact.social.map((social) => (
              <InlineLink
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <social.icon className="text-muted-foreground hover:text-foreground size-4 fill-current transition-colors" />
                <span>{social.name}</span>
              </InlineLink>
            ))
          }
        </div>
      </PageHero>

      <!-- Work -->
      {
        RESUME_DATA.work.length > 0 && (
          <SectionStack>
            <SectionTitle>Work</SectionTitle>
            <CardStack>
              {RESUME_DATA.work.map((work) => (
                <a
                  href={work.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <GlassCard class="p-6 hover:-translate-y-0.5">
                    <div class="space-y-3">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 space-y-1">
                          <h3 class="text-foreground font-medium">
                            {work.company}
                          </h3>
                          <p class="text-muted-foreground text-sm">
                            {work.title}
                          </p>
                        </div>
                        <span class="text-muted-foreground text-sm whitespace-nowrap">
                          {work.start}—{work.end}
                        </span>
                      </div>
                      <p class="text-muted-foreground text-sm leading-relaxed">
                        {work.description}
                      </p>
                    </div>
                  </GlassCard>
                </a>
              ))}
            </CardStack>
          </SectionStack>
        )
      }

      <!-- Skills -->
      <div class="grid gap-16 md:grid-cols-2">
        <SectionStack>
          <SectionTitle>Languages</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.languages.map((lang) => <Chip>{lang}</Chip>)}
            </div>
          </div>
        </SectionStack>

        <SectionStack>
          <SectionTitle>Tools</SectionTitle>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.tools.map((tool) => <Chip>{tool}</Chip>)}
            </div>
          </div>
        </SectionStack>
      </div>
    </PageStack>
  </PageShell>
</MainLayout>
