---
import MainLayout from '@/layouts/MainLayout.astro';
import { Badge, Card } from '@almach/ui';
import { RESUME_DATA } from '@/data/resume-data';
import { MailIcon } from 'lucide-react';
---

<MainLayout>
  <div class="container mx-auto max-w-5xl px-6 py-20">
    <div class="space-y-20">
      <!-- Hero -->
      <section class="max-w-3xl space-y-8">
        <div class="space-y-6">
          <h1 class="text-5xl font-medium tracking-tight md:text-6xl">
            {RESUME_DATA.name}
          </h1>
          <p class="text-muted-foreground text-lg leading-relaxed md:text-xl">
            {RESUME_DATA.about}
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          {RESUME_DATA.skills.map((skill) => <Badge>{skill}</Badge>)}
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {
            RESUME_DATA.contact.email && (
              <a
                href={`mailto:${RESUME_DATA.contact.email}`}
                class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 transition-colors"
              >
                <MailIcon className="size-4" />
                <span>Email</span>
              </a>
            )
          }
          {
            RESUME_DATA.contact.social.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 transition-colors"
              >
                <social.icon className="size-4 fill-current" />
                <span>{social.name}</span>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Work -->
      {
        RESUME_DATA.work.length > 0 && (
          <section class="space-y-6">
            <h2 class="text-muted-foreground text-xs font-medium tracking-widest uppercase">
              Work
            </h2>
            <div class="space-y-4">
              {RESUME_DATA.work.map((work) => (
                <a
                  href={work.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <Card className="border-border/50 bg-card/50 p-6 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-foreground/20 hover:bg-card/80 hover:shadow-sm">
                    <div class="space-y-3">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 space-y-1">
                          <h3 class="text-foreground font-medium">
                            {work.company}
                          </h3>
                          <p class="text-muted-foreground text-sm">
                            {work.title}
                          </p>
                        </div>
                        <span class="text-muted-foreground text-sm whitespace-nowrap">
                          {work.start}—{work.end}
                        </span>
                      </div>
                      <p class="text-muted-foreground text-sm leading-relaxed">
                        {work.description}
                      </p>
                    </div>
                  </Card>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Skills -->
      <div class="grid gap-16 md:grid-cols-2">
        <section class="space-y-6">
          <h2
            class="text-muted-foreground text-xs font-medium tracking-widest uppercase"
          >
            Languages
          </h2>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.languages.map((lang) => <Badge>{lang}</Badge>)}
            </div>
          </div>
        </section>

        <section class="space-y-6">
          <h2
            class="text-muted-foreground text-xs font-medium tracking-widest uppercase"
          >
            Tools
          </h2>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {RESUME_DATA.tools.map((tool) => <Badge>{tool}</Badge>)}
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</MainLayout>
