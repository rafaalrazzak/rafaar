---
import MainLayout from '@/layouts/MainLayout.astro';
import { RESUME_DATA } from '@/data/resume-data';
import { projects } from '@/data/links/projects';
import GlassCard from '@/components/ui/GlassCard.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import InlineLink from '@/components/ui/InlineLink.astro';
---

<MainLayout title="Links">
  <div class="page-shell">
    <div class="page-stack">
      <!-- Header -->
      <section class="page-hero">
        <div class="space-y-6">
          <h1 class="page-heading">Links</h1>
          <p class="page-lead">
            Connect with me across the web.
          </p>
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {
            RESUME_DATA.contact.social.map((social) => (
              <InlineLink
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <social.icon className="icon-tone size-4 fill-current" />
                <span>{social.name}</span>
              </InlineLink>
            ))
          }
        </div>
      </section>

      <!-- Projects -->
      <section class="section-stack">
        <SectionTitle>Projects</SectionTitle>
        <div class="card-stack">
          {
            projects.map((project) => (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="block">
                <GlassCard class="p-6 hover:-translate-y-0.5">
                  <div class="flex items-start gap-4">
                    <div class="glass-panel flex size-12 shrink-0 items-center justify-center rounded-lg">
                    <project.icon className="icon-tone size-6" />
                    </div>
                    <div class="flex-1 space-y-1">
                      <h3 class="text-main font-medium">{project.title}</h3>
                      <p class="text-soft text-sm">
                        {project.description}
                      </p>
                    </div>
                  </div>
                </GlassCard>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</MainLayout>
